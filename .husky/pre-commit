#!/bin/sh
set -e

ROOT="$(git rev-parse --show-toplevel)"

# frontend/
if git diff --cached --name-only | grep -q '^frontend/'; then
  echo "frontend/: Running lint..."
  (cd "$ROOT/frontend" && npm run lint)
  echo "frontend/: Running type-check..."
  (cd "$ROOT/frontend" && npm run type-check)
fi

# admin/
if git diff --cached --name-only | grep -q '^admin/'; then
  echo "admin/: Running lint..."
  (cd "$ROOT/admin" && npm run lint)
  echo "admin/: Running type-check..."
  (cd "$ROOT/admin" && npm run type-check)
fi
